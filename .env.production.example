VITE_APP_ENV=production
# Leave these blank only for the Pages + D1 path.
# For the full split stack, set:
# VITE_API_BASE_URL=https://api.bop-game.com/api/v1
# VITE_WS_BASE_URL=wss://ws.bop-game.com/ws
VITE_API_BASE_URL=https://api.bop-game.com/api/v1
VITE_WS_BASE_URL=wss://ws.bop-game.com/ws
VITE_USE_BACKEND_MATCHING=true

# Keep this disabled in production.
VITE_ENABLE_LOCAL_AUTH_BYPASS=false

# Clerk
VITE_CLERK_ENABLED=false
VITE_CLERK_PUBLISHABLE_KEY=
VITE_CLERK_SIGN_IN_URL=
VITE_CLERK_SIGN_UP_URL=
VITE_CLERK_AFTER_SIGN_IN_URL=https://bop-game.pages.dev
VITE_CLERK_AFTER_SIGN_UP_URL=https://bop-game.pages.dev

# Stripe
VITE_STRIPE_ENABLED=false
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_STRIPE_DEFAULT_PRODUCT_KEY=coins_1200

# Supabase
VITE_SUPABASE_ENABLED=false
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_AVATAR_BUCKET=avatars

# PostHog
VITE_POSTHOG_ENABLED=false
VITE_POSTHOG_API_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Sentry
VITE_SENTRY_ENABLED=false
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=production
VITE_SENTRY_TRACES_SAMPLE_RATE=0.2
