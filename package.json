    "@supabase/supabase-js": "^2.100.0",
    "animejs": "^4.3.6",
    "gsap": "^3.14.2",
    "posthog-js": "^1.363.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
