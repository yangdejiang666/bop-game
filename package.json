    "deploy:env:split": "node ./scripts/bootstrap-split-prod-env.mjs",
    "deploy:check:pages": "node ./scripts/check-deploy-readiness.mjs --mode pages-d1",
    "deploy:check:split": "node ./scripts/check-deploy-readiness.mjs --mode split-stack",
    "preview": "vite preview",
    "smoke:cloud": "node ./scripts/smoke-cloud-stack.mjs",
    "local:start": "node ./scripts/start-local-stack.mjs",
    "local:start:fast": "node ./scripts/start-local-stack.mjs --skip-build",
    "local:stop": "node ./scripts/stop-local-stack.mjs"
  },
  "devDependencies": {
