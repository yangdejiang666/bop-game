{
  "name": "@bop/api-server",
  "version": "0.1.0",
  "private": true,
  "description": "BOP API server for auth, user/profile, matchmaking, and room orchestration.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "prepare:protocol": "npm --prefix ../shared-protocol run build",
    "dev": "npm run prepare:protocol && tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "build": "npm run prepare:protocol && tsc -p tsconfig.json",
    "check": "npm run prepare:protocol && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@bop/shared-protocol": "file:../shared-protocol",
    "@alicloud/dysmsapi20170525": "^4.1.2",
    "@alicloud/openapi-client": "^0.4.15",
    "@clerk/backend": "^3.2.2",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/jwt": "^9.0.1",
    "@fastify/rate-limit": "^10.1.0",
    "@fastify/sensible": "^5.6.0",
    "@pinecone-database/pinecone": "^7.1.0",
    "@sentry/node": "^10.45.0",
    "@supabase/supabase-js": "^2.100.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "fastify": "^5.6.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "nanoid": "^5.1.5",
    "pg": "^8.20.0",
    "posthog-node": "^5.28.5",
    "resend": "^6.9.4",
    "stripe": "^20.4.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "tsx": "^4.20.5",
    "typescript": "~5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
